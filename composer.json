{
    "name": "filament-inbox/filament-inbox",
    "description": "Email-like inbox messaging plugin for Filament v5",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.2",
        "filament/filament": "^5.0",
        "spatie/laravel-package-tools": "^1.14"
    },
    "autoload": {
        "psr-4": {
            "FilamentInbox\\": "src/",
            "FilamentInbox\\Database\\Factories\\": "database/factories/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "FilamentInbox\\FilamentInboxServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
